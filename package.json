{
  "name": "StepperCardChallenge",
  "version": "0.0.1",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "android": "react-native run-android",
    "android:assembleDebug": "cd android && ./gradlew assembleDebug",
    "bundle:android": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output /tmp/stepper-card-android/index.android.bundle --assets-dest /tmp/stepper-card-android",
    "bundle:ios": "react-native bundle --platform ios --dev false --entry-file index.js --bundle-output /tmp/stepper-card-ios/main.jsbundle --assets-dest /tmp/stepper-card-ios",
    "check:package-manager": "node scripts/check-package-manager.js",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "ios": "react-native run-ios",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "start": "react-native start",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native/new-app-screen": "0.85.2",
    "i18next": "^26.0.7",
    "react": "19.2.3",
    "react-i18next": "^17.0.4",
    "react-native": "0.85.2",
    "react-native-localize": "^3.7.0",
    "react-native-safe-area-context": "^5.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.85.2",
    "@react-native/eslint-config": "0.85.2",
    "@react-native/jest-preset": "0.85.2",
    "@react-native/metro-config": "0.85.2",
    "@react-native/typescript-config": "0.85.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.19.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-unused-imports": "^4.2.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
